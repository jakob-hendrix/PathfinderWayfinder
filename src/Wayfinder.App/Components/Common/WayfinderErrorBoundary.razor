@using Wayfinder.App.Services
@inject AppLoggingService AppLogger
@inherits ErrorBoundary

@if (CurrentException is null)
{
  @ChildContent
}
else
{
  @* This replaces the "Reload" button with some useful info *@
  <div class="alert alert-danger m-3 shadow-sm border-start border-5 border-danger">
    <h5 class="alert-heading">
      <i class="bi bi-exclamation-triangle-fill me-2"></i>
      Calculation Error
    </h5>
    <p class="mb-0">The Pathfinder engine encountered some rule conflict:</p>
    <hr />
    <small class="text-monospace">@CurrentException.Message</small>
    <div class="mt-3">
      <button class="btn btn-sm btn-danger" @onclick="Recover">Reset View</button>
    </div>
  </div>
}


@code {
  protected override Task OnErrorAsync(Exception exception)
  {
    AppLogger.LogError("UI Component Exception", exception);
    return Task.CompletedTask;
  }
}
