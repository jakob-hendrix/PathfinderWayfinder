@using Wayfinder.Core.Constants
@using Wayfinder.Core.DataDefinitions
@using Wayfinder.Core.Models.Items
@using Wayfinder.App.ViewModels
@using Wayfinder.App.Components.Common

@* --- INVENTORY GROUPS --- *@
<div class="d-flex flex-column gap-4">
    <InventoryItemGroup Title="Weapons" 
                        Items="VM.Weapons" 
                        CategoryType="ItemType.Weapon" 
                        VM="VM" 
                        OnAddClicked="OpenItemLibrary" />

    <InventoryItemGroup Title="Armor" 
                        Items="VM.Armor" 
                        CategoryType="ItemType.Armor" 
                        VM="VM" 
                        OnAddClicked="OpenItemLibrary" />

    <InventoryItemGroup Title="Shields" 
                        Items="VM.Shields" 
                        CategoryType="ItemType.Shield" 
                        VM="VM" 
                        OnAddClicked="OpenItemLibrary" />

    <InventoryItemGroup Title="Adventuring Gear" 
                        Items="VM.AdventuringGear" 
                        CategoryType="ItemType.AdventuringGear" 
                        VM="VM" 
                        OnAddClicked="OpenItemLibrary" />
</div>

@* --- THE MODAL OVERLAY --- *@
<GenericPickerModal TItem="ItemDefinition"
                    IsOpen="@_isPickerOpen"
                    Title="@_pickerTitle"
                    Items="@_pickerTemplates"
                    GetName="@(item => item.Name)"
                    GetSubText="@(item => $"{item.Weight} lbs | {item.Cost}")"
                    GetSearchString="@(item => $"{item.Name} {item.ItemType}")"
                    OnItemSelected="HandleItemSelected"
                    OnClosed="() => _isPickerOpen = false" />

@code {
    [Parameter, EditorRequired]
    public InventoryViewModel VM { get; set; } = default!;

    // --- Modal State ---
    private bool _isPickerOpen;
    private string _pickerTitle = "Select Item";
    private IEnumerable<ItemDefinition> _pickerTemplates = Array.Empty<ItemDefinition>();

    // Triggers when any child InventoryItemGroup fires its OnAddClicked event
    private void OpenItemLibrary((string Title, ItemType Type) request)
    {
        _pickerTitle = $"Add {request.Title}";
        _pickerTemplates = VM.GetLibraryTemplates(request.Type);
        _isPickerOpen = true;
    }

    private void HandleItemSelected(ItemDefinition selectedItem)
    {
        VM.AddItemFromLibrary(selectedItem.Id);
        _isPickerOpen = false;
    }
}
