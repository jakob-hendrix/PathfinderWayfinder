@using Wayfinder.Core.Models.Characters

<style>
    .pf-hp-card {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        border: 2px solid #212529;
        border-radius: 4px;
        background-color: #fff;
    }

    .pf-hp-header {
        background-color: #212529;
        color: #fff;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 1px;
        padding: 0.25rem 0.5rem;
        font-size: 0.85rem;
        text-align: center;
    }

    .hp-display-row {
        display: flex;
        border-bottom: 2px solid #212529;
    }

    .hp-box {
        flex: 1;
        padding: 0.5rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .hp-box-label {
        font-size: 0.65rem;
        font-weight: bold;
        text-transform: uppercase;
        color: #6c757d;
        margin-bottom: 0.2rem;
    }

    .hp-max-value {
        font-size: 1.5rem;
        font-weight: bold;
        color: #495057;
    }

    .hp-current-value {
        font-size: 2rem; /* Massive font for the most important number */
        font-weight: 900;
        line-height: 1;
    }

    /* Warning color for low/negative HP */
    .text-danger-heavy {
        color: #dc3545 !important;
    }

    .hp-input-row {
        display: flex;
        background-color: #f8f9fa;
    }

    .hp-input-group {
        flex: 1;
        padding: 0.4rem;
        border-right: 1px solid #dee2e6;
        text-align: center;
    }

        .hp-input-group:last-child {
            border-right: none;
        }

    .hp-input {
        width: 100%;
        text-align: center;
        font-weight: bold;
        font-size: 1rem;
        padding: 0.1rem;
        border: 1px solid #adb5bd;
        border-radius: 3px;
    }

        /* Hide the spinner arrows on number inputs for a cleaner look */
        .hp-input::-webkit-outer-spin-button,
        .hp-input::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
</style>

@if (VM?.ActiveSheet != null)
{
    <div class="pf-hp-card shadow-sm mb-3">
        <div class="pf-hp-header">
            Hit Points
        </div>

        @* TOP ROW: Read-Only Displays *@
        <div class="hp-display-row">
            <div class="hp-box" style="background-color: #e9ecef; border-right: 2px solid #212529;">
                <span class="hp-box-label">Total / Max</span>
                <span class="hp-max-value">@VM.MaxHp</span>
            </div>
            <div class="hp-box">
                <span class="hp-box-label">Current HP</span>
                <span class="hp-current-value @(VM.CurrentHp <= 0 ? "text-danger-heavy" : "text-dark")">
                    @VM.CurrentHp
                </span>
            </div>
        </div>

        @* BOTTOM ROW: Two-Way Bound Inputs *@
        <div class="hp-input-row">
            <div class="hp-input-group">
                <label class="hp-box-label d-block">Wounds</label>
                @* bind-value:event="oninput" ensures the UI updates on every keystroke *@
                <input type="number"
                       class="hp-input"
                       min="0"
                       @bind-value="VM.Wounds"
                       @bind-value:event="oninput" />
            </div>

            <div class="hp-input-group">
                <label class="hp-box-label d-block" title="Temporary Hit Points">Temp HP</label>
                <input type="number"
                       class="hp-input text-primary"
                       min="0"
                       @bind-value="VM.TemporaryHp"
                       @bind-value:event="oninput" />
            </div>

            <div class="hp-input-group">
                <label class="hp-box-label d-block" title="Non-Lethal Damage">Non-Lethal</label>
                <input type="number"
                       class="hp-input text-warning"
                       min="0"
                       @bind-value="VM.NonLethalDamage"
                       @bind-value:event="oninput" />
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public CharacterSheetViewModel VM { get; set; }
}
