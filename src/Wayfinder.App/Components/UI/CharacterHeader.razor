@using Wayfinder.Core.DomainModels
@using Wayfinder.Core.Models.Characters
@* Adjust the using statement above to wherever your CharacterSheet lives *@

<style>
    .pf-header-card {
        background-color: #fff;
        border: 2px solid #212529;
        border-radius: 4px;
        padding: 0.75rem;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .pf-header-field {
        border-bottom: 2px solid #212529;
        position: relative;
        padding-bottom: 0.1rem;
        margin-bottom: 0.5rem;
        min-height: 2.2rem; /* Keeps empty boxes from collapsing */
        display: flex;
        align-items: flex-end;
    }

    .pf-header-label {
        position: absolute;
        bottom: -16px;
        left: 0;
        font-size: 0.65rem;
        font-weight: bold;
        text-transform: uppercase;
        color: #6c757d;
    }

    .pf-header-value {
        font-size: 1.1rem;
        font-weight: bold;
        color: #212529;
        line-height: 1;
        width: 100%;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .pf-name-value {
        font-size: 1.75rem;
        font-weight: 800;
        font-family: Georgia, serif; /* Gives the name a classic RPG feel */
    }
</style>

@if (VM?.ActiveCharacterSheet != null)
{
    <div class="pf-header-card shadow-sm mb-4">
        <div class="row g-3 pb-2">

            @* TOP ROW: Name, Alignment, Class & Level *@
            <div class="col-md-4 col-sm-12">
                <div class="pf-header-field">
                    <div class="pf-header-value pf-name-value text-primary">
                        @(string.IsNullOrWhiteSpace(VM.ActiveCharacterSheet.BaseCharacter.Name) ? "Unnamed Hero" : VM.ActiveCharacterSheet.BaseCharacter.Name)
                    </div>
                    <div class="pf-header-label">Character Name</div>
                </div>
            </div>

            <div class="col-md-2 col-4">
                <div class="pf-header-field">
                    <div class="pf-header-value">
                        @VM.Alignment
                    </div>
                    <div class="pf-header-label">Alignment</div>
                </div>
            </div>

            <div class="col-md-6 col-8">
                <div class="pf-header-field">
                    <div class="pf-header-value">
                        @VM.ActiveCharacterSheet.ClassSummary <span class="text-muted ms-2 fs-6">(Level @TotalLevel)</span>
                    </div>
                    <div class="pf-header-label">Class and Level</div>
                </div>
            </div>

            @* BOTTOM ROW: Race, Size, Gender, Deity, etc. *@
            <div class="col-md-3 col-6">
                <div class="pf-header-field">
                    <div class="pf-header-value">@VM.RaceFullTitle</div>
                    <div class="pf-header-label">Race / Ancestry</div>
                </div>
            </div>

            @*         <div class="col-md-2 col-6">
            <div class="pf-header-field">
                <div class="pf-header-value text-center">@Sheet.BaseCharacter.Size</div>
                <div class="pf-header-label">Size</div>
            </div>
        </div> *@

            <div class="col-md-2 col-4">
                <div class="pf-header-field">
                    <div class="pf-header-value">@VM.Gender</div>
                    <div class="pf-header-label">Gender</div>
                </div>
            </div>

            <div class="col-md-5 col-8">
                <div class="pf-header-field">
                    <div class="pf-header-value">@VM.Deity</div>
                    <div class="pf-header-label">Deity</div>
                </div>
            </div>

        </div>
    </div>
}

