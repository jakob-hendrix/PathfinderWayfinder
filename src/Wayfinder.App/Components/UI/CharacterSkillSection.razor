@using Wayfinder.Core.Constants
@using Wayfinder.Core.DomainModels.Stats

<style>
    .pf-skill-card {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        border: 2px solid #212529;
        border-radius: 4px;
        background-color: #fff;
    }

    .pf-skill-header {
        background-color: #212529;
        color: #fff;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 1px;
        padding: 0.25rem 0.5rem;
        font-size: 0.85rem;
        display: flex;
    }

    .pf-skill-row {
        display: flex;
        align-items: center;
        border-bottom: 1px solid #dee2e6;
        padding: 0.25rem 0;
        font-size: 0.9rem;
    }

        .pf-skill-row:last-child {
            border-bottom: none;
        }

        .pf-skill-row:nth-child(even) {
            background-color: #f8f9fa;
        }

        .pf-skill-row:hover {
            background-color: #e2e6ea;
        }

    /* Column Sizing */
    .col-cs {
        width: 5%;
        text-align: center;
        font-weight: bold;
    }

    .col-name {
        width: 45%;
        padding-left: 0.5rem;
    }

    .col-total {
        width: 15%;
        text-align: center;
        font-weight: 900;
        background-color: #e9ecef;
        border-radius: 4px;
    }

    .col-math {
        width: 11.66%;
        text-align: center;
        color: #495057;
    }

    .skill-ability {
        font-size: 0.7rem;
        color: #6c757d;
        text-transform: uppercase;
    }

    .unusable-skill {
        opacity: 0.5;
        font-style: italic;
    }
</style>

@if (VM.ActiveSheet != null && VM.ActiveSheet.Skills != null)
{
    <div class="pf-skill-card shadow-sm mb-3">
        @* HEADER ROW *@
        <div class="pf-skill-header">
            <div class="col-cs" title="Class Skill">CS</div>
            <div class="col-name">Skill Name</div>
            <div class="col-total">Total</div>
            <div class="col-math" title="Ability Modifier">Ability</div>
            <div class="col-math" title="Ranks Invested">Ranks</div>
            <div class="col-math" title="Miscellaneous Modifiers">Misc</div>
        </div>

        @* SKILL ROWS *@
        @foreach (var skill in VM.ActiveSheet.Skills)
        {
            // Dim the row if the player has no ranks in a Trained-Only skill
            string usableClass = skill.IsUsable ? "" : "unusable-skill";

            <div class="pf-skill-row @usableClass">
                @* 1. Class Skill Checkbox/Indicator *@
                <div class="col-cs">
                    @(skill.IsClassSkill ? "☑" : "☐")
                </div>

                @* 2. Name & Key Ability *@
                <div class="col-name">
                    <strong>@skill.Name</strong>
                    @if (skill.IsTrainedOnly)
                    {
                        <span class="text-danger" title="Trained Only">*</span>
                    }
                    <span class="skill-ability">(@skill.KeyAbility.ToString().Substring(0, 3))</span>
                </div>

                @* 3. The Total (Wrapped in the Tooltip!) *@
                <div class="col-total">
                    <StatTooltip Stat="skill.Score">
                        <div class="w-100 py-1" style="cursor: help;">
                            @FormatMod(skill.Score.Total)
                        </div>
                    </StatTooltip>
                </div>

                @* 4. Ability Mod Breakdown *@
                <div class="col-math">
                    @FormatMod(skill.AbilityModifier)
                </div>

                @* 5. Ranks Breakdown *@
                <div class="col-math">
                    @skill.TotalRanks
                </div>

                @* 6. Misc Breakdown *@
                <div class="col-math">
                    @FormatMod(skill.MiscBonus)
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter, EditorRequired]
    public CharacterSheetViewModel VM { get; set; } = default!;

    private string FormatMod(int mod)
    {
        return mod >= 0 ? $"+{mod}" : mod.ToString();
    }
}
