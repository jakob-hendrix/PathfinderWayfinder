@using Wayfinder.Core.DomainModels.Skills
@using Wayfinder.Core.Extensions

<style>
    /* Ultra-Compact Classic RPG Sheet Styling */
    .pf-skill-section {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        border: 2px solid #212529;
        border-radius: 4px;
        background-color: #fff;
    }

    .pf-skill-header {
        background-color: #212529;
        color: #fff;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 1px;
        padding: 0.15rem 0.5rem;
        font-size: 0.85rem;
    }

    .pf-table {
        width: 100%;
        font-size: 0.75rem; /* Shrunk for narrow column */
        border-collapse: collapse;
        white-space: nowrap; /* Prevent ugly wrapping */
    }

        .pf-table th {
            border-bottom: 2px solid #212529;
            padding: 2px;
            text-align: center;
            font-size: 0.65rem; /* Tiny headers like the paper sheet */
            color: #495057;
            text-transform: uppercase;
        }

        .pf-table td {
            padding: 1px 2px; /* Razor-thin padding */
            vertical-align: middle;
            border-bottom: 1px solid #dee2e6;
        }

        .pf-table tbody tr:nth-child(even) {
            background-color: #f8f9fa;
        }

    .cs-box {
        display: inline-block;
        width: 12px;
        height: 12px;
        border: 1px solid #212529;
        text-align: center;
        line-height: 10px;
        font-size: 9px;
        font-weight: bold;
        margin-right: 4px;
    }

    .total-box {
        font-weight: bold;
        font-size: 0.85rem;
        text-align: center;
        width: 30px; /* Shrunk */
        border: 1px solid #212529;
        background-color: #e9ecef;
    }

    .math-box {
        text-align: center;
        width: 25px; /* Shrunk */
        border-bottom: 1px solid #6c757d;
    }

    .math-operator {
        color: #6c757d;
        font-weight: bold;
        padding: 0 1px;
        font-size: 0.7rem;
    }
</style>

<div class="pf-skill-section shadow-sm mb-3">
    <div class="pf-skill-header">
        Skills
    </div>

    <table class="pf-table">
        <thead>
            <tr>
                <th style="text-align: left; width: 100%;">Skill Name</th>
                <th title="Total Bonus">Total</th>
                <th></th>
                <th title="Ability Modifier">Abil</th>
                <th></th>
                <th title="Ranks">Rank</th>
                <th></th>
                <th title="Miscellaneous Modifier">Misc</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var skill in Skills.Where(s => s.IsUsable))
            {
                int miscMod = skill.TotalBonus - skill.TotalRanks - skill.AbilityModifier;

                <tr>
                    <td class="text-truncate" style="max-width: 120px;">
                        <div class="d-flex align-items-center">
                            <span class="cs-box" title="Class Skill">@(skill.IsClassSkill ? "X" : "")</span>
                            <span class="fw-bold text-truncate @(skill.IsTrainedOnly ? "fst-italic" : "")">
                                @skill.Name
                            </span>
                            <span class="text-muted ms-1" style="font-size: 0.65rem;">
                                @skill.KeyAbility.AbbreviateAbilityScore()
                            </span>
                            @if (skill.IsBackground)
                            {
                                <i class="bi bi-book-half text-info ms-1" style="font-size: 0.65rem;" title="Background Skill"></i>
                            }
                        </div>
                    </td>

                    <td class="total-box">
                        @(skill.TotalBonus >= 0 ? "+" : "")@skill.TotalBonus
                    </td>
                    <td class="math-operator">=</td>
                    <td class="math-box">
                        @(skill.AbilityModifier >= 0 ? "+" : "")@skill.AbilityModifier
                    </td>
                    <td class="math-operator">+</td>
                    <td class="math-box">@skill.TotalRanks</td>
                    <td class="math-operator">+</td>
                    <td class="math-box text-muted">@miscMod</td>
                </tr>
            }
        </tbody>
    </table>
    <div class="p-1 text-muted text-end" style="font-size: 0.65rem; background-color: #f8f9fa;">
        <span class="fst-italic me-2">Italics = Trained Only</span>
        <span class="cs-box" style="margin-right: 2px;">X</span> = Class Skill
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public IReadOnlyList<CalculatedSkill> Skills { get; set; } = new List<CalculatedSkill>();
}
