<style>
    .pf-save-card {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        border: 2px solid #212529;
        border-radius: 4px;
        background-color: #fff;
    }

    .pf-save-header {
        background-color: #212529;
        color: #fff;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 1px;
        padding: 0.25rem 0.5rem;
        font-size: 0.85rem;
        text-align: center;
    }

    .pf-save-row {
        display: flex;
        align-items: stretch;
        border-bottom: 1px solid #dee2e6;
    }

        .pf-save-row:last-child {
            border-bottom: none;
        }

        .pf-save-row:nth-child(even) {
            background-color: #f8f9fa;
        }

    .save-name {
        width: 65%;
        font-weight: bold;
        font-size: 1rem;
        padding: 0.5rem;
        padding-left: 0.75rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        border-right: 2px solid #212529;
        color: #212529;
    }

    .save-ability {
        font-size: 0.65rem;
        color: #6c757d;
        font-weight: normal;
        text-transform: uppercase;
        margin-top: -2px;
    }

    .save-total-container {
        width: 35%;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #e9ecef;
    }

    .save-total {
        font-size: 1.5rem;
        font-weight: 900;
        color: #212529;
        /* Ensure the div takes up the full space for a bigger hover target */
        width: 100%;
        text-align: center;
        padding: 0.5rem 0;
    }
</style>

@if (VM.ActiveSheet != null)
{
    <div class="pf-save-card shadow-sm mb-3">
        <div class="pf-save-header">
            Saving Throws
        </div>

        @* Fortitude *@
        <div class="pf-save-row">
            <div class="save-name">
                Fortitude <span class="save-ability">(Constitution)</span>
            </div>
            <div class="save-total-container">
                <StatTooltip Stat="VM.FortitudeSave">
                    <div class="save-total">@FormatMod(VM.FortitudeSave.Total)</div>
                </StatTooltip>
            </div>
        </div>

        @* Reflex *@
        <div class="pf-save-row">
            <div class="save-name">
                Reflex <span class="save-ability">(Dexterity)</span>
            </div>
            <div class="save-total-container">
                <StatTooltip Stat="VM.ReflexSave">
                    <div class="save-total">@FormatMod(VM.ReflexSave.Total)</div>
                </StatTooltip>
            </div>
        </div>

        @* Will *@
        <div class="pf-save-row">
            <div class="save-name">
                Will <span class="save-ability">(Wisdom)</span>
            </div>
            <div class="save-total-container">
                <StatTooltip Stat="VM.WillSave">
                    <div class="save-total">@FormatMod(VM.WillSave.Total)</div>
                </StatTooltip>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public CharacterSheetViewModel VM { get; set; } = default!;

    // Pure UI Presentation Logic
    private string FormatMod(int mod)
    {
        return mod >= 0 ? $"+{mod}" : mod.ToString();
    }
}
