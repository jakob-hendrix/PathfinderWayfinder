@using Wayfinder.Core.DataDefinitions
@using Wayfinder.Core.Models.Characters
@using Wayfinder.Core.Rules.Engines

<div class="card shadow-sm border-primary sticky-top" style="top: 20px;">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Edit Heritage</h5>
    </div>
    <div class="card-body">
        @if (VM.ActiveCharacter != null)
        {
            <div class="mb-3">
                <label class="form-label fw-bold text-secondary">Base Race</label>
                <select class="form-select" value="@(VM.ActiveCharacter.RaceChoices.RaceName)" @onchange="OnBaseRaceChanged">
                    <option value="">-- Select Race --</option>
                    @foreach (var r in VM.AvailableRaces)
                    {
                        <option value="@r.Name">@r.Name</option>
                    }
                </select>
            </div>

            @if (SelectedDefinition != null)
            {
                <hr class="text-muted" />

                @if (SelectedDefinition.Subraces.Any())
                {
                    <div class="mb-4">
                        <label class="form-label fw-bold text-secondary">Subrace / Ethnic Heritage</label>
                        <select class="form-select" value="@(VM.ActiveCharacter.RaceChoices.SubraceName)" @onchange="OnSubraceChanged">
                            <option value="">Standard / Default</option>
                            @foreach (var sub in SelectedDefinition.Subraces)
                            {
                                <option value="@sub.Name">@sub.Name</option>
                            }
                        </select>
                    </div>
                }

                <div class="mb-4">
                    <label class="form-label fw-bold text-secondary">Base Racial Traits</label>
                    <div class="list-group">
                        @foreach (var defaultTrait in SelectedDefinition.DefaultRacialTraits)
                        {
                            bool isReplaced = IsTraitReplaced(defaultTrait.Name);
                            <div class="list-group-item @(isReplaced ? "bg-light text-muted opacity-75" : "bg-white")">
                                <div class="d-flex justify-content-between align-items-center">
                                    <strong class="@(isReplaced ? "text-decoration-line-through" : "")">@defaultTrait.Name</strong>
                                    @if (isReplaced)
                                    {
                                        <span class="badge bg-danger x-small">Replaced</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                @if (SelectedDefinition.AlternativeRacialTraits.Any())
                {
                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary">Alternative Traits</label>
                        <div class="list-group trait-list">
                            @foreach (var alt in GetValidAlternativeOptions())
                            {
                                bool isSelected = VM.ActiveCharacter.RaceChoices.SelectedAlternativeTraits.Contains(alt.Name);

                                <button type="button"
                                        class="list-group-item list-group-item-action @(isSelected ? "active" : "")"
                                        @onclick="() => ToggleAltTrait(alt.Name)">
                                    <div class="d-flex w-100 justify-content-between align-items-center">
                                        <strong class="mb-1">@alt.Name</strong>
                                        @if (isSelected)
                                        {
                                            <i class="bi bi-check-circle-fill"></i>
                                        }
                                    </div>
                                    <small class="x-small @(isSelected ? "text-light" : "text-danger")">
                                        Replaces: @string.Join(", ", alt.ReplacesRacialTraits)
                                    </small>
                                </button>
                            }
                        </div>
                    </div>
                }
            }
        }
    </div>
</div>

@code {
    @code {
        [CascadingParameter] public BaseCharacterViewModel VM { get; set; } = null!;

        private RaceDefinition? SelectedDefinition =>
            VM.AvailableRaces.FirstOrDefault(r => r.Name.EqualsIgnoreCase(VM.ActiveCharacter?.RaceChoices.RaceName));

        private Subrace? ActiveSubraceDef =>
            SelectedDefinition?.Subraces.FirstOrDefault(s => s.Name.EqualsIgnoreCase(VM.ActiveCharacter?.RaceChoices.SubraceName));

        protected override void OnInitialized()
        {
            VM.PropertyChanged += OnViewModelPropertyChanged;

            if (VM.ActiveCharacter?.RaceChoices != null && !string.IsNullOrEmpty(VM.ActiveCharacter.RaceChoices.RaceName) && VM.ActiveSheet?.Race == null)
            {
                VM.NotifyRaceChanged();
            }
        }

        private void OnViewModelPropertyChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
        {
            InvokeAsync(StateHasChanged);
        }

        public void Dispose()
        {
            if (VM != null) VM.PropertyChanged -= OnViewModelPropertyChanged;
        }

        private bool IsTraitReplaced(string traitName)
        {
            if (VM.ActiveSheet?.Race == null) return false;
            if (!VM.ActiveSheet.Race.RaceDefinition.Name.EqualsIgnoreCase(SelectedDefinition?.Name)) return false;
            return !VM.ActiveSheet.Race.SelectedRacialTraits.Any(t => t.Name.EqualsIgnoreCase(traitName));
        }

        // --- The Explicit Handlers ---

        private void OnBaseRaceChanged(ChangeEventArgs e)
        {
            var newId = e.Value?.ToString() ?? "";

            // Only trigger the cascade if the race actually changed
            if (VM.ActiveCharacter != null && !newId.EqualsIgnoreCase(VM.ActiveCharacter.RaceChoices.RaceName))
            {
                VM.ActiveCharacter.RaceChoices.RaceName = newId;
                VM.ActiveCharacter.RaceChoices.SubraceName = null;
                VM.ActiveCharacter.RaceChoices.SelectedAlternativeTraits.Clear();

                VM.NotifyRaceChanged();
            }
        }

        private void OnSubraceChanged(ChangeEventArgs e)
        {
            var newId = e.Value?.ToString();
            newId = string.IsNullOrWhiteSpace(newId) ? null : newId;

            if (VM.ActiveCharacter != null && !newId.EqualsIgnoreCase(VM.ActiveCharacter.RaceChoices.SubraceName))
            {
                VM.ActiveCharacter.RaceChoices.SubraceName = newId;
                VM.ActiveCharacter.RaceChoices.SelectedAlternativeTraits.Clear();

                VM.NotifyRaceChanged();
            }
        }

        private void ToggleAltTrait(string traitName)
        {
            var list = VM.ActiveCharacter!.RaceChoices.SelectedAlternativeTraits;
            if (list.Contains(traitName)) list.Remove(traitName);
            else list.Add(traitName);

            VM.NotifyRaceChanged();
        }

        private IEnumerable<AlternativeRacialTrait> GetValidAlternativeOptions()
        {
            if (SelectedDefinition == null) return Enumerable.Empty<AlternativeRacialTrait>();

            var currentSelections = SelectedDefinition.AlternativeRacialTraits
                .Where(t => VM.ActiveCharacter!.RaceChoices.SelectedAlternativeTraits.Contains(t.Name))
                .ToList();

            var available = RacialTraitEngine.GetAvailableAlternatives(SelectedDefinition, ActiveSubraceDef, currentSelections);

            return currentSelections.Concat(available).DistinctBy(x => x.Name);
        }
    }
}

<style>
    .trait-list {
        max-height: 350px;
        overflow-y: auto;
    }

    .x-small {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
</style>
