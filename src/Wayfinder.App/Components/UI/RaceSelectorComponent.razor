@using Wayfinder.Core.Data.Definitions
@using Wayfinder.Core.DomainModels.Characters.RaceModels
@using Wayfinder.Core.Extensions
@using Wayfinder.Core.Rules.Services

<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Race Selection</h5>
    </div>
    <div class="card-body">
        @if (VM.Character == null)
        {
            <p>Loading character data...</p>
        }
        else
        {
            @* @/* 1. Base Race Dropdown */ *@
            <div class="mb-3">
                <label class="form-label fw-bold">Base Race</label>
                <select class="form-select" @onchange="OnBaseRaceChanged">
                    <option value="">-- Select Race --</option>
                    @foreach (var r in VM.AvailableRaces)
                    {
                        <option value="@r.Id" selected="@(VM.Character.RaceChoices.RaceName == r.Id)">@r.Name</option>
                    }
                </select>
            </div>

            @if (SelectedDefinition != null)
            {
                <hr />

                @* @/* 2. Subrace Dropdown */ *@
                <div class="mb-3">
                    <label class="form-label fw-bold">Subrace (Optional)</label>
                    <select class="form-select" @onchange="OnSubraceChanged">
                        <option value="">Standard / Default</option>
                        @foreach (var sub in SelectedDefinition.Subraces)
                        {
                            <option value="@sub.Id" selected="@(VM.Character.RaceChoices.SubraceName == sub.Id)">@sub.Name</option>
                        }
                    </select>
                    @if (ActiveSubraceDef != null)
                    {
                        <div class="form-text mt-2 p-2 bg-light border-start border-3 border-warning">
                            @ActiveSubraceDef.Description
                        </div>
                    }
                </div>

                @* @/* 3. Alternative Racial Traits */ *@
                <div class="mb-3">
                    <label class="form-label fw-bold">Alternative Racial Traits</label>
                    <div class="list-group">
                        @foreach (var alt in GetValidAlternativeOptions())
                        {
                            bool isSelected = VM.Character.RaceChoices.SelectedAlternativeTraitIds.Contains(alt.Id);
                            
                            <button type="button" 
                                    class="list-group-item list-group-item-action @(isSelected ? "active" : "")"
                                    @onclick="() => ToggleAltTrait(alt.Id)">
                                <div class="d-flex w-100 justify-content-between">
                                    <h6 class="mb-1">@alt.Name</h6>
                                </div>
                                <p class="mb-1 small">@alt.Description</p>
                                <small class="text-uppercase" style="font-size: 0.7rem;">
                                    Replaces: @string.Join(", ", alt.ReplacesTraitNames)
                                </small>
                            </button>
                        }
                    </div>
                </div>

                @* @/* 4. Assembled Traits Summary (The Domain Truth) */ *@
                <div class="mt-4 p-3 border rounded bg-light">
                    <h6>Assembled Racial Traits:</h6>
                    <div class="d-flex flex-wrap gap-1">
                        @foreach (var trait in VM.Character?.Race?.SelectedRacialTraits ?? new())
                        {
                            <span class="badge bg-dark">@trait.Name</span>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    [CascadingParameter] public BaseCharacterViewModel VM { get; set; } = null!;

    protected override void OnInitialized()
    {
        // If we have choices but no hydrated race, trigger a re-sync immediately
        if (VM.RaceChoices != null &&
            !string.IsNullOrEmpty(VM.RaceChoices.RaceName) &&
            VM.ActiveSheet?.Race == null)
        {
            VM.NotifyRaceChanged();
        }
    }

    // Helper to get the actual definition from the library based on current ID
    private RaceDefinition? SelectedDefinition => 
    VM.AvailableRaces.FirstOrDefault(r => r.Id == VM.Character?.RaceChoices.RaceName);

    private Subrace? ActiveSubraceDef => 
        SelectedDefinition?.Subraces.FirstOrDefault(s => s.Id == VM.Character?.RaceChoices.SubraceName);

    private void OnBaseRaceChanged(ChangeEventArgs e)
    {
        var id = e.Value?.ToString() ?? "";
        VM.Character!.RaceChoices.RaceName = id;
        VM.Character.RaceChoices.SubraceName = null;
        VM.Character.RaceChoices.SelectedAlternativeTraitIds.Clear();
        VM.NotifyRaceChanged();
    }

    private void OnSubraceChanged(ChangeEventArgs e)
    {
        VM.Character!.RaceChoices.SubraceName = e.Value?.ToString();
        // Clear conflicting individual alts when changing a subrace bundle
        VM.Character.RaceChoices.SelectedAlternativeTraitIds.Clear();
        VM.NotifyRaceChanged();
    }

    private void ToggleAltTrait(string traitId)
    {
        var list = VM.Character!.RaceChoices.SelectedAlternativeTraitIds;
        if (list.Contains(traitId))
            list.Remove(traitId);
        else
            list.Add(traitId);

        VM.NotifyRaceChanged();
    }

    private IEnumerable<AlternativeRacialTrait> GetValidAlternativeOptions()
    {
        if (SelectedDefinition == null) return Enumerable.Empty<AlternativeRacialTrait>();

        // We ask the Engine: "Based on the subrace and current traits, what else is legal?"
        // We include already selected traits so they stay visible and can be toggled off.
        var currentSelections = SelectedDefinition.AlternativeRacialTraits
            .Where(t => VM.Character!.RaceChoices.SelectedAlternativeTraitIds.Contains(t.Id))
            .ToList();

        var available = RacialTraitEngine.GetAvailableAlternatives(
            SelectedDefinition, 
            ActiveSubraceDef, 
            currentSelections);

        return currentSelections.Concat(available).DistinctBy(x => x.Id);
    }
}
