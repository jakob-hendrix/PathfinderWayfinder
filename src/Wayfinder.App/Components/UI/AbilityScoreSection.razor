@using Wayfinder.Core.Logic
@using Wayfinder.Core.Models.Characters
@using Wayfinder.Core.Rules.Calculators

<style>
    .pf-ability-card {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        border: 2px solid #212529;
        border-radius: 4px;
        background-color: #fff;
    }

    .pf-ability-header {
        background-color: #212529;
        color: #fff;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 1px;
        padding: 0.25rem 0.5rem;
        font-size: 0.85rem;
        text-align: center;
    }

    .pf-ability-row {
        display: flex;
        align-items: stretch;
        border-bottom: 1px solid #dee2e6;
    }

        .pf-ability-row:last-child {
            border-bottom: none;
        }

        .pf-ability-row:nth-child(even) {
            background-color: #f8f9fa;
        }

    .ability-name {
        width: 30%;
        font-weight: bold;
        font-size: 1.1rem;
        padding: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border-right: 2px solid #212529;
        color: #212529;
    }

    /* CHANGED: Container holds the grid column width and border */
    .ability-score-container {
        width: 35%;
        display: flex;
        align-items: center;
        justify-content: center;
        border-right: 1px solid #dee2e6;
    }

    /* CHANGED: Inner div handles text sizing and hover area */
    .ability-score {
        font-size: 1.25rem;
        width: 100%;
        text-align: center;
        padding: 0.5rem 0;
        cursor: help;
    }

    .ability-mod {
        width: 35%;
        font-size: 1.5rem;
        font-weight: 900;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #e9ecef;
        color: #212529;
    }

    .ability-subheader {
        display: flex;
        background-color: #e9ecef;
        border-bottom: 2px solid #212529;
        font-size: 0.65rem;
        font-weight: bold;
        color: #6c757d;
        text-transform: uppercase;
        text-align: center;
    }

    .sub-col {
        flex: 1;
        padding: 2px 0;
    }
</style>

@if (VM.ActiveSheet != null)
{
    <div class="pf-ability-card shadow-sm mb-3">
        <div class="pf-ability-header">
            Ability Scores
        </div>

        <div class="ability-subheader">
            <div class="sub-col" style="flex: 0 0 30%; border-right: 2px solid #212529;">Ability</div>
            <div class="sub-col" style="flex: 0 0 35%; border-right: 1px solid #dee2e6;">Score</div>
            <div class="sub-col" style="flex: 0 0 35%;">Modifier</div>
        </div>

        @* STR *@
        <div class="pf-ability-row">
            <div class="ability-name" title="Strength">STR</div>
            <div class="ability-score-container">
                <StatTooltip Stat="VM.Strength">
                    <div class="ability-score">@VM.Strength.Total</div>
                </StatTooltip>
            </div>
            <div class="ability-mod">@AbilityScoreCalculator.CalculateModifier(VM.Strength).FormatModifier()</div>
        </div>

        @* DEX *@
        <div class="pf-ability-row">
            <div class="ability-name" title="Dexterity">DEX</div>
            <div class="ability-score-container">
                <StatTooltip Stat="VM.Dexterity">
                    <div class="ability-score">@VM.Dexterity.Total</div>
                </StatTooltip>
            </div>
            <div class="ability-mod">@AbilityScoreCalculator.CalculateModifier(VM.Dexterity).FormatModifier()</div>
        </div>

        @* CON *@
        <div class="pf-ability-row">
            <div class="ability-name" title="Constitution">CON</div>
            <div class="ability-score-container">
                <StatTooltip Stat="VM.Constitution">
                    <div class="ability-score">@VM.Constitution.Total</div>
                </StatTooltip>
            </div>
            <div class="ability-mod">@AbilityScoreCalculator.CalculateModifier(VM.Constitution).FormatModifier()</div>
        </div>

        @* INT *@
        <div class="pf-ability-row">
            <div class="ability-name" title="Intelligence">INT</div>
            <div class="ability-score-container">
                <StatTooltip Stat="VM.Intelligence">
                    <div class="ability-score">@VM.Intelligence.Total</div>
                </StatTooltip>
            </div>
            <div class="ability-mod">@AbilityScoreCalculator.CalculateModifier(VM.Intelligence).FormatModifier()</div>
        </div>

        @* WIS *@
        <div class="pf-ability-row">
            <div class="ability-name" title="Wisdom">WIS</div>
            <div class="ability-score-container">
                <StatTooltip Stat="VM.Wisdom">
                    <div class="ability-score">@VM.Wisdom.Total</div>
                </StatTooltip>
            </div>
            <div class="ability-mod">@AbilityScoreCalculator.CalculateModifier(VM.Wisdom).FormatModifier()</div>
        </div>

        @* CHA *@
        <div class="pf-ability-row">
            <div class="ability-name" title="Charisma">CHA</div>
            <div class="ability-score-container">
                <StatTooltip Stat="VM.Charisma">
                    <div class="ability-score">@VM.Charisma.Total</div>
                </StatTooltip>
            </div>
            <div class="ability-mod">@AbilityScoreCalculator.CalculateModifier(VM.Charisma).FormatModifier()</div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public CharacterSheetViewModel VM { get; set; } = default!;
}
