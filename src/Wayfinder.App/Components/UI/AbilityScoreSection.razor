@using Wayfinder.Core.Logic
@using Wayfinder.Core.Models.Characters
@using Wayfinder.Core.Rules.Calculators

<style>
    .pf-ability-card {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        border: 2px solid #212529;
        border-radius: 4px;
        background-color: #fff;
    }

    .pf-ability-header {
        background-color: #212529;
        color: #fff;
        text-transform: uppercase;
        font-weight: bold;
        letter-spacing: 1px;
        padding: 0.25rem 0.5rem;
        font-size: 0.85rem;
        text-align: center;
    }

    .pf-ability-row {
        display: flex;
        align-items: stretch;
        border-bottom: 1px solid #dee2e6;
    }

        .pf-ability-row:last-child {
            border-bottom: none;
        }

        .pf-ability-row:nth-child(even) {
            background-color: #f8f9fa;
        }

    .ability-name {
        width: 30%;
        font-weight: bold;
        font-size: 1.1rem;
        padding: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border-right: 2px solid #212529;
        color: #212529;
    }

    .ability-score {
        width: 35%;
        font-size: 1.25rem;
        display: flex;
        align-items: center;
        justify-content: center;
        border-right: 1px solid #dee2e6;
    }

    .ability-mod {
        width: 35%;
        font-size: 1.5rem;
        font-weight: 900;
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: #e9ecef;
        color: #212529;
    }

    .ability-subheader {
        display: flex;
        background-color: #e9ecef;
        border-bottom: 2px solid #212529;
        font-size: 0.65rem;
        font-weight: bold;
        color: #6c757d;
        text-transform: uppercase;
        text-align: center;
    }

    .sub-col {
        flex: 1;
        padding: 2px 0;
    }
</style>

@if (VM.ActiveCharacterSheet != null)
{
    <div class="pf-ability-card shadow-sm mb-3">
        <div class="pf-ability-header">
            Ability Scores
        </div>

        <div class="ability-subheader">
            <div class="sub-col" style="flex: 0 0 30%; border-right: 2px solid #212529;">Ability</div>
            <div class="sub-col" style="flex: 0 0 35%; border-right: 1px solid #dee2e6;">Score</div>
            <div class="sub-col" style="flex: 0 0 35%;">Modifier</div>
        </div>

        @* STR *@
        <div class="pf-ability-row">
            <div class="ability-name" title="Strength">STR</div>
            <div class="ability-score">@VM.Strength</div>
            <div class="ability-mod">@FormatMod(AbilityScoreCalculator.CalculateModifier(VM.Strength))</div>
        </div>

        @* DEX *@
        <div class="pf-ability-row">
            <div class="ability-name" title="Dexterity">DEX</div>
            <div class="ability-score">@VM.Dexterity</div>
            <div class="ability-mod">@FormatMod(AbilityScoreCalculator.CalculateModifier(VM.Dexterity))</div>
        </div>

        @* CON *@
        <div class="pf-ability-row">
            <div class="ability-name" title="Constitution">CON</div>
            <div class="ability-score">@VM.Constitution</div>
            <div class="ability-mod">@FormatMod(AbilityScoreCalculator.CalculateModifier(VM.Constitution))</div>
        </div>

        @* INT *@
        <div class="pf-ability-row">
            <div class="ability-name" title="Intelligence">INT</div>
            <div class="ability-score">@VM.Intelligence</div>
            <div class="ability-mod">@FormatMod(AbilityScoreCalculator.CalculateModifier(VM.Intelligence))</div>
        </div>

        @* WIS *@
        <div class="pf-ability-row">
            <div class="ability-name" title="Wisdom">WIS</div>
            <div class="ability-score">@VM.Wisdom</div>
            <div class="ability-mod">@FormatMod(AbilityScoreCalculator.CalculateModifier(VM.Wisdom))</div>
        </div>

        @* CHA *@
        <div class="pf-ability-row">
            <div class="ability-name" title="Charisma">CHA</div>
            <div class="ability-score">@VM.Charisma</div>
            <div class="ability-mod">@FormatMod(AbilityScoreCalculator.CalculateModifier(VM.Charisma))</div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired]
    public CharacterSheetViewModel VM { get; set; }

    // Pure UI Presentation Logic: Formatting the domain's integer for tabletop display
    private string FormatMod(int mod)
    {
        return mod >= 0 ? $"+{mod}" : mod.ToString();
    }
}
