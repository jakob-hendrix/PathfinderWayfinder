@page "/class-levels"
@using Wayfinder.UI.ViewModels
@inject ClassLevelsViewModel VM

<div class="container-fluid py-4">
    <h2 class="mb-4">Class Progression</h2>
    @* Force a horizontal flex layout for the two main columns *@
    <div style="display: flex; flex-direction: row; gap: 2rem; width: 100%; align-items: flex-start;">

        @* LEFT NAV COLUMN: Strictly 25% width, forced into a vertical column *@
        <div style="width: 25%; display: flex; flex-direction: column; gap: 0.5rem; border-right: 1px solid #dee2e6; padding-right: 1rem;">

            @foreach (var level in VM.CurrentLevels)
            {
                <button class="btn @(VM.ViewingLevelIndex == level.CharacterLevel ? "btn-primary" : "btn-outline-secondary") text-start"
                        @onclick="() => VM.ViewHistoricalLevel(level.CharacterLevel)">
                    <strong>Level @level.CharacterLevel:</strong> @level.ClassDefinition.Name
                </button>
            }

            @if (VM.CurrentLevels.Count < 20)
            {
                <button class="btn btn-success fw-bold mt-2"
                        @onclick="VM.StartNewLevelCommand.Execute">
                    + Add Level @(VM.CurrentLevels.Count + 1)
                </button>
            }

            @if (VM.CurrentLevels.Any())
            {
                <button class="btn btn-outline-danger mt-4"
                        @onclick="VM.RemoveTopLevelCommand.Execute">
                    Delete Level @VM.CurrentLevels.Count
                </button>
            }
        </div>

        @* RIGHT DETAIL COLUMN: Takes up the remaining 75% width *@
        <div style="width: 75%;">
            @if (VM.ActiveDraft != null)
            {
                <ClassLevelDetailComponent DraftVM="VM.ActiveDraft"
                                           AvailableClasses="VM.AvailableClasses"
                                           OnSaveClicked="VM.SaveDraftCommand.Execute" />
            }
            else if (VM.ViewingLevelIndex.HasValue)
            {
                var pastLevel = VM.CurrentLevels.FirstOrDefault(l => l.CharacterLevel == VM.ViewingLevelIndex.Value);
                if (pastLevel != null)
                {
                    <div class="alert alert-secondary shadow-sm">
                        <h4 class="alert-heading">Level @pastLevel.CharacterLevel - @pastLevel.ClassDefinition.Name</h4>
                        <hr />
                        <p class="mb-0">This level is locked in the character's history. To change choices made at this level, you must delete levels from the top of the stack down to this point.</p>
                    </div>
                }
            }
            else
            {
                <div class="text-muted mt-5 text-center">
                    <h5>Select a level to view details, or add a new level.</h5>
                </div>
            }
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        VM.PropertyChanged += (s, e) => InvokeAsync(StateHasChanged);
    }
}
