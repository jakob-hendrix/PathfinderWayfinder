@page "/"
@using Wayfinder.Core.Extensions
@using Wayfinder.Core.Rules.Calculators
@inject CharacterSheetViewModel VM

<div class="container-fluid py-4">
    @if (VM.ActiveSheet == null)
    {
        <div class="alert alert-warning">No character active. Please load or create a character first.</div>
    }
    else
    {
        <div class="px-2">
            @* TOP HEADER *@
            <div class="row mb-4">
                <div class="col-12">
                    <CharacterHeader VM="VM" />
                </div>
            </div>

            @* MOVEMENT ROW *@
            <div class="row mb-3">
                <div class="col-12">
                    <MovementSection VM="@VM" />
                </div>
            </div>

            @* ENCUMBRANCE ROW *@
            <div class="row mb-4">
                <div class="col-12">
                    <EncumbranceSection VM="@VM" />
                </div>
            </div>

            @* THE CSS GRID START *@
            <div class="sheet-main-grid">

                @* ========================================== *@
                @* LEFT COLUMN: Core Stats & Combat           *@
                @* ========================================== *@
                <div class="sheet-left-wrapper">

                    @* The Inner 50/50 Split Grid *@
                    <div class="sheet-left-grid">

                        @* INNER-LEFT: Abilities and Saves *@
                        <div class="d-flex flex-column gap-3">
                            <AbilityScoreSection VM="VM" />
                            <SavingThrowSection VM="VM" />
                        </div>

                        @* INNER-RIGHT: HP, Combat, Attacks *@
                        <div class="d-flex flex-column gap-3">
                            <HitPointSection VM="VM" />

                            <div class="alert alert-secondary text-center shadow-sm">
                                <strong>Armor Class Component</strong><br />(Coming Soon)
                            </div>

                            <div class="alert alert-secondary text-center shadow-sm">
                                <strong>Attacks Component</strong><br />(Coming Soon)
                            </div>
                        </div>

                    </div>
                </div>

                @* ========================================== *@
                @* RIGHT COLUMN: Skills                       *@
                @* ========================================== *@
                <div class="sheet-right-wrapper">
                    <CharacterSkillSection VM="VM" />
                </div>

            </div>
            @* THE CSS GRID END *@

        </div>
    }
</div>
