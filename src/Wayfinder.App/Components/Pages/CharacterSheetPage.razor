@page "/"
@using Wayfinder.Core.Extensions
@using Wayfinder.Core.Rules.Services
@inject CharacterSheetViewModel ViewModel

<div class="container py-4">
    @if (ViewModel.ActiveCharacterSheet == null)
    {
        <div class="alert alert-warning">No character active. Please load or create a character first.</div>
    }
    else
    {
        <div class="row">
            @* @/* --- LEFT COLUMN: Identity & Demographics --- */ *@
            <div class="col-md-4">
                <section class="mb-4">
                    <h2 class="display-6 border-bottom">@ViewModel.ActiveCharacterSheet.BaseCharacterFacts.Name</h2>
                    
                    <div class="stat-group mt-3">
                        <div class="stat-line"><strong>Race:</strong> @ViewModel.RaceFullTitle</div>
                        <div class="stat-line"><strong>Alignment:</strong> @ViewModel.Alignment</div>
                        <div class="stat-line"><strong>Gender:</strong> @ViewModel.Gender</div>
                        <div class="stat-line"><strong>Age:</strong> @ViewModel.Age</div>
                        <div class="stat-line"><strong>Deity:</strong> @ViewModel.Deity</div>
                    </div>
                </section>

                @* @/* --- ABILITY SCORES --- */ *@
                <section class="mb-4 p-3 bg-light rounded shadow-sm">
                    <h4 class="text-secondary border-bottom pb-2">Ability Scores</h4>
                    <div class="ability-grid">
                        <div class="stat-line">
                            <strong>Strength:</strong> 
                            <span class="fw-bold">@ViewModel.Strength (@FormatMod(ViewModel.Strength))</span>
                        </div>
                        <div class="stat-line">
                            <strong>Dexterity:</strong> 
                            <span class="fw-bold">@ViewModel.Dexterity (@FormatMod(ViewModel.Dexterity))</span>
                        </div>
                        <div class="stat-line">
                            <strong>Constitution:</strong> 
                            <span class="fw-bold">@ViewModel.Constitution (@FormatMod(ViewModel.Constitution))</span>
                        </div>
                        <div class="stat-line">
                            <strong>Intelligence:</strong> 
                            <span class="fw-bold">@ViewModel.Intelligence (@FormatMod(ViewModel.Intelligence))</span>
                        </div>
                        <div class="stat-line">
                            <strong>Wisdom:</strong> 
                            <span class="fw-bold">@ViewModel.Wisdom (@FormatMod(ViewModel.Wisdom))</span>
                        </div>
                        <div class="stat-line">
                            <strong>Charisma:</strong> 
                            <span class="fw-bold">@ViewModel.Charisma (@FormatMod(ViewModel.Charisma))</span>
                        </div>
                    </div>
                </section>
            </div>

            @* @/* --- RIGHT COLUMN: Heritage & Detailed Features --- */ *@
            <div class="col-md-8">
                
                @* @/* Racial Traits Section */ *@
                <section class="mb-4">
                    <h4 class="text-secondary border-bottom pb-2">Racial Heritage</h4>
                    @if (ViewModel.ActiveTraits.Any())
                    {
                        @if (ViewModel.CurrentRace?.Subrace != null)
                        {
                            <div class="alert alert-secondary py-2 small mb-3">
                                <strong>Subrace: @ViewModel.CurrentRace.Subrace.Name</strong> — 
                                @ViewModel.CurrentRace.Subrace.Description
                            </div>
                        }

                        <div class="row">
                            @foreach (var trait in ViewModel.ActiveTraits)
                            {
                                <div class="col-12 mb-3 border-start border-3 border-primary ps-3">
                                    <div class="d-flex justify-content-between">
                                        <span class="fw-bold text-dark"><strong>@trait.Name</strong></span>
                                        @if (ViewModel.CurrentRace?.ActiveAlternativeRacialTraits.Any(a => a.Name == trait.Name) == true)
                                        {
                                            <span class="badge bg-warning text-dark x-small">Alternative</span>
                                        }
                                    </div>
                                    <div class="text-muted small">@trait.Description</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted italic">No race data available. Ensure a race is selected in the character foundations.</div>
                    }
                </section>

                @* @/* Biography & Physical Description */ *@
                <section class="mb-4">
                    <h4 class="text-secondary border-bottom pb-2">Story</h4>
                    <div class="mb-3">
                        <label class="text-uppercase small fw-bold text-muted">Physical Description</label>
                        <p class="border p-2 bg-white rounded">@ViewModel.ActiveCharacterSheet.BaseCharacterFacts.PhysicalDescription</p>
                    </div>
                    <div>
                        <label class="text-uppercase small fw-bold text-muted">Biography</label>
                        <div class="border p-2 bg-white rounded biography-box">
                            @((MarkupString)(ViewModel.ActiveCharacterSheet.BaseCharacterFacts.Biography?.Replace("\n", "<br />") ?? "<em>No history recorded.</em>"))
                        </div>
                    </div>
                </section>
            </div>
        </div>
    }
</div>

@code {
    private string FormatMod(int stat)
    {
        var mod = AbilityScoreCalculator.CalculateModifier(stat);
        return mod >= 0 ? $"+{mod}" : mod.ToString();
    }

    protected override void OnInitialized()
    {
        // Subscribe to state changes so the UI refreshes if the user switches characters or updates facts
        ViewModel.PropertyChanged += (s, e) => StateHasChanged();
    }
}

<style>
    .stat-line {
        display: flex;
        justify-content: flex-start;
        padding: 5px 0;
        border-bottom: 1px solid #eee;
    }

    .stat-line strong {
        min-width: 120px;
        color: #555;
    }

    .biography-box {
        min-height: 150px;
        line-height: 1.6;
    }

    .x-small {
        font-size: 0.65rem;
    }
</style>
