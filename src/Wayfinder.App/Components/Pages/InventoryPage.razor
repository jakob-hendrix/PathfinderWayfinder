@page "/inventory"
@inject InventoryViewModel VM
@inject CharacterStateService StateService
@implements IDisposable

@if (!VM.HasActiveCharacter)
{
    <div class="p-4">
        <div class="alert alert-warning shadow-sm">No character active. Please load or create a character first.</div>
    </div>
}
else
{
    <div class="page-wrapper">

        @* DOCKED TOP TABS *@
        <div class="sub-nav-header">
            <ul class="nav nav-tabs sub-nav-tabs">
                <li class="nav-item">
                    <button class="nav-link @(VM.ActiveTab == 0 ? "active" : "")" @onclick="() => SetTab(0)">
                        <i class="bi bi-list-ul me-2"></i> Inventory List
                    </button>
                </li>
                <li class="nav-item">
                    <button class="nav-link @(VM.ActiveTab == 1 ? "active" : "")" @onclick="() => SetTab(1)">
                        <i class="bi bi-person-bounding-box me-2"></i> Equipped Gear
                    </button>
                </li>
            </ul>
        </div>

        @* SCROLLABLE CONTENT AREA *@
        <div class="page-scroll-content">
            @if (VM.ActiveTab == 0)
            {
                <InventoryListSection VM="VM" />
            }
            else if (VM.ActiveTab == 1)
            {
                <EquipmentSection VM="VM" />
            }
        </div>

    </div>
}

@code {
    protected override void OnInitialized()
    {
        StateService.StateChanged += StateHasChanged;
        base.OnInitialized();
    }

    private void SetTab(int index)
    {
        VM.ActiveTab = index;
    }

    public void Dispose()
    {
        StateService.StateChanged -= StateHasChanged;
    }
}
