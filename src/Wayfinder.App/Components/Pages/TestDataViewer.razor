@page "/view-data"
@using Wayfinder.Core.Domain.Models
@using Wayfinder.Core.DataServices
@inject IRaceService RaceService


<PageTitle>Data Viewer For Testing</PageTitle>

<div class="container mt-4">
  <h1>Race Data</h1>
  <p class="text-muted">Loaded from Data/Races.json</p>

  @if (_races is null)
  {
    <div class="spinner-border text-primary" role="status">
      <span class="visually-hidden">Loading...</span>
    </div>
  }
  else
  {
    <div class="row">
      @foreach (var race in _races)
      {
        <div class="col-md-4 mb-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <h5 class="card-title text-primary">@race.Name</h5>

              <p class="card-text">
                <strong>Size:</strong> @race.Size<br />
                <strong>Speed:</strong> @race.BaseSpeed<br />
                <strong>Creature Type:</strong> @race.CreatureType<br />
                @foreach (var subType in race.CreatureSubTypes)
                {
                  <strong>Subtype:</strong> 
                  @subType
            
                  <br />
                }
                <div class="bg-light p-2 rounded">
                  <strong>Ability Score Modifiers:</strong>
                  <ul class="list-unstyled mb-0">
                    @foreach (var modifier in race.AbilityModifiers)
                    {
                      <li class="@(modifier.Value > 0 ? "text-success" : "text-danger")" ">
                        @(modifier.Value > 0 ? "+" : "-")@modifier.Value @modifier.Ability
                      </li>
                    }
                  </ul>
                </div>
              </p>
            </div>
          </div>
        </div>
      }
    </div>
  }
</div>

@code {
  private List<Race>? _races;
  protected override async Task OnInitializedAsync()
  {
    _races = await RaceService.GetAllRacesAsync();
  }
}
